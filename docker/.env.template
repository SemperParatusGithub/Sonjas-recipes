# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Your domain (apex — www is redirected to this automatically)
DOMAIN=yourdomain.com

# Let's Encrypt notification email
ACME_EMAIL=you@yourdomain.com

# Traefik dashboard basic-auth (user:bcrypt-hash)
# Generate with: htpasswd -nB admin
# Example (admin / changeme):
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$somehashhere
