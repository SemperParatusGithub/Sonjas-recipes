# Docker production environment template
# Copy to .env and fill in your values

# Domain configuration
DOMAIN=yourdomain.com
RECIPES_DOMAIN=recipes.yourdomain.com

# Traefik Dashboard Auth
# Generate with: htpasswd -nb admin <password> | cut -d: -f2
TRAEFIK_DASHBOARD_AUTH=admin:$apr1$H6uskkkW$IgXLP6ewTrSuBkTrqE8wj/  # CHANGE THIS

# Let's Encrypt (use staging for testing)
ACME_EMAIL=admin@yourdomain.com
# Use staging CA first, then switch to production
LETSENCRYPT_CA=https://acme-staging-v02.api.letsencrypt.org/directory
# LETSENCRYPT_CA=https://acme-v02.api.letsencrypt.org/directory  # Production

# Recipe App Database
DB_HOST=recipe-db
DB_PORT=5432
DB_NAME=recipes
DB_USER=recipeuser
DB_PASSWORD=  # Set your password here
